:: [EN] Wait time in seconds between starting game instances
:: [CH] 启动后杀线程的等待时间（秒） .
set secs=8

:: [EN] Server Address (e.g., kr.actual.battle.net for Asia, us.actual.battle.net for America)
:: [CH] 服务器地址（亚服：kr.actual.battle.net，美服：us.actual.battle.net，欧服：eu.actual.battle.net） .
set addres="kr.actual.battle.net"

:: ==========================================
:: Path Settings / 路径配置 .
:: ==========================================

:: [EN] Main game executable path (D2R.exe)
:: [CH] 游戏主程序 (D2R.exe) 所在的完整路径 .
:: [CH] 此为全局默认值；可通过 accounts_secrets.bat 中的 ACCOUNT_x_DIABLO 为单个账号指定不同路径 .
:: [EN] This is the global default; override per-account via ACCOUNT_x_DIABLO in accounts_secrets.bat.
set diablo="D:\BlizzardGame\d2r\D2R.exe"

:: [EN] Directory containing the multi-boxing tools (handle.exe, NewTitle.exe)
:: [CH] 存放多开辅助工具（handle.exe 和 NewTitle.exe）的所在目录 .
::      请不要给这个路径加引号 / Do not add quotes here
set workdir=D:\BlizzardGame\d2r\bootdiablo

:: ==========================================
:: Monitor and Layout Settings / 显示器和布局配置
:: ==========================================

:: [CH] 显示器编号列表：使用与 Windows「设置 > 系统 > 屏幕」中相同的编号，用空格分隔 .
:: [CH] 例如只用显示器 1 和 3：set MONITOR_IDS=1 3  （可以跳号） .
:: [EN] List of display numbers matching Windows Settings > System > Display, space-separated.
:: [EN] Example: if you use Display 1 and Display 3, set MONITOR_IDS=1 3 (gaps OK).
set MONITOR_IDS=1

:: [CH] 非游玩窗口的固定大小（像素）：这些窗口仅为凑人数而启动，不需要操作 .
:: [EN] Fixed size for non-play windows (px). These are launched just to fill party slots.
set DEFAULT_WIN_W=1280
set DEFAULT_WIN_H=720
set MIN_WIN_W=800
set MIN_WIN_H=600

:: [CH] 游玩窗口（PRIMARY=1）的默认大小（像素）：这是你实际操作的主窗口 .
:: [EN] Default size for play windows (PRIMARY=1). This is the window you actually play on.
set PRIMARY_WIN_W=1920
set PRIMARY_WIN_H=1080

:: ------------------------------------------
:: Display 1 / 显示器 1（对应 Windows 屏幕设置中的编号 1）
:: ------------------------------------------
:: [CH] W/H = 物理分辨率（像素），SCALE = Windows 缩放百分比（如 100、125、150） .
:: [CH] X/Y = 该显示器在 Windows 多屏坐标系中的左上角位置（主显示器通常为 0,0） .
:: [CH] TASKBAR = 该显示器的任务栏高度（像素），避免窗口被遮挡 .
:: [EN] W/H = physical resolution, SCALE = Windows DPI scaling %, X/Y = top-left offset in virtual desktop, TASKBAR = taskbar height.
set MON_1_W=1920
set MON_1_H=1080
set MON_1_SCALE=100
set MON_1_X=0
set MON_1_Y=0
set MON_1_TASKBAR=40

:: ------------------------------------------
:: Display 2 / 显示器 2（对应 Windows 编号 2，取消注释并修改即可启用）
:: ------------------------------------------
:: set MON_2_W=2560
:: set MON_2_H=1440
:: set MON_2_SCALE=100
:: set MON_2_X=1920
:: set MON_2_Y=0
:: set MON_2_TASKBAR=0

:: ------------------------------------------
:: Display 3 / 显示器 3（对应 Windows 编号 3，取消注释并修改即可启用）
:: ------------------------------------------
:: set MON_3_W=1920
:: set MON_3_H=1080
:: set MON_3_SCALE=100
:: set MON_3_X=-1920
:: set MON_3_Y=0
:: set MON_3_TASKBAR=0

:: ------------------------------------------
:: Auto-generated tool paths (Usually no need to modify)
:: 自动生成工具路径（通常无需修改） .
:: ------------------------------------------

:: handle.exe Download/下载地址: https://learn.microsoft.com/zh-cn/sysinternals/downloads/handle
set myhandler="%workdir%\handle.exe"

:: NewTitle.exe: Community tool / 社区自制小工具 .
set newtitle="%workdir%\NewTitle.exe"
