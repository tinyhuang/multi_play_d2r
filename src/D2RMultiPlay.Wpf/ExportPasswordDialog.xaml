<Window x:Class="D2RMultiPlay.Wpf.ExportPasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Set Export Passphrase" Height="320" Width="420"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Background="{ui:ThemeResource ApplicationBackgroundBrush}"
        Foreground="{ui:ThemeResource ApplicationForegroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="LblExportPassphrase" Grid.Row="0" Margin="0,0,0,4" />
        <PasswordBox x:Name="PasswordBox1" Grid.Row="1" Height="32" Padding="8" Margin="0,0,0,8" />

        <TextBlock x:Name="LblExportPassphraseConfirm" Grid.Row="2" Margin="0,0,0,4" />
        <PasswordBox x:Name="PasswordBox2" Grid.Row="3" Height="32" Padding="8" Margin="0,0,0,12" />

        <CheckBox x:Name="ChkIncludePasswords" Grid.Row="4" IsChecked="True" Margin="0,0,0,8" />

        <TextBlock x:Name="LblExportWarning" Grid.Row="5" Foreground="OrangeRed" FontSize="10" TextWrapping="Wrap" Margin="0,4,0,8" />

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnCancelExport" IsCancel="True" Width="80" Margin="0,0,8,0" />
            <Button x:Name="BtnOkExport" Click="BtnOk_Click" Width="80" />
        </StackPanel>
    </Grid>
</Window>
