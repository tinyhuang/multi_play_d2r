<Window x:Class="D2RMultiPlay.Wpf.ExportPasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Set Export Passphrase" Height="320" Width="420"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Background="{ui:ThemeResource ApplicationBackgroundBrush}"
        Foreground="{ui:ThemeResource ApplicationForegroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Passphrase (min 8 characters):" Margin="0,0,0,4" />
        <PasswordBox x:Name="PasswordBox1" Grid.Row="1" Height="32" Padding="8" Margin="0,0,0,8" />

        <TextBlock Grid.Row="2" Text="Confirm passphrase:" Margin="0,0,0,4" />
        <PasswordBox x:Name="PasswordBox2" Grid.Row="3" Height="32" Padding="8" Margin="0,0,0,12" />

        <CheckBox x:Name="ChkIncludePasswords" Grid.Row="4" Content="Include account passwords (portable, encrypted with your passphrase)" IsChecked="True" Margin="0,0,0,8" />

        <TextBlock Grid.Row="5" Text="⚠ If you lose this passphrase, the exported file CANNOT be recovered." 
                   Foreground="OrangeRed" FontSize="10" TextWrapping="Wrap" Margin="0,4,0,8" />

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Content="Cancel" IsCancel="True" Width="80" />
            <Button Content="OK" Click="BtnOk_Click" Width="80" />
        </StackPanel>
    </Grid>
</Window>
