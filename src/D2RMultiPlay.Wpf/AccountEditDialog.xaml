<Window x:Class="D2RMultiPlay.Wpf.AccountEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Account Editor" Height="520" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{ui:ThemeResource ApplicationBackgroundBrush}"
        Foreground="{ui:ThemeResource ApplicationForegroundBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Name" Margin="0,0,0,4"/>
        <TextBox x:Name="TxtName" Grid.Row="1" Height="32" Margin="0,0,0,8"/>

        <TextBlock Grid.Row="2" Text="Email / Username" Margin="0,0,0,4"/>
        <TextBox x:Name="TxtUser" Grid.Row="3" Height="32" Margin="0,0,0,8"/>

        <TextBlock Grid.Row="4" Text="Password" Margin="0,0,0,4"/>
        <PasswordBox x:Name="TxtPassword" Grid.Row="5" Height="32" Margin="0,0,0,8"/>

        <Grid Grid.Row="6" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Role" Margin="0,0,0,4"/>
                <ComboBox x:Name="CmbRole" Height="32">
                    <ComboBoxItem Content="master" IsSelected="True"/>
                    <ComboBoxItem Content="slave"/>
                </ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Enabled" Margin="0,0,0,4"/>
                <CheckBox x:Name="ChkEnabled" IsChecked="True" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="7" Text="Custom Icon (optional)" Margin="0,0,0,4"/>
        <Grid Grid.Row="8" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TxtIconPath" Grid.Column="0" Height="32"/>
            <Button Grid.Column="2" Content="Browse..." Click="BtnBrowseIcon_Click" MinWidth="88"/>
        </Grid>

        <TextBlock Grid.Row="9" Text="Server Override (optional)" Margin="0,0,0,4"/>
        <TextBox x:Name="TxtServer" Grid.Row="10" Height="32" VerticalAlignment="Top"/>

        <StackPanel Grid.Row="11" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" IsCancel="True" MinWidth="88" Margin="0,0,8,0"/>
            <Button Content="OK" Click="BtnOk_Click" MinWidth="88"/>
        </StackPanel>
    </Grid>
</Window>
