<Window x:Class="D2RMultiPlay.Wpf.GlobalSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Global Settings" Height="560" Width="620"
        WindowStartupLocation="CenterOwner"
        Background="{ui:ThemeResource ApplicationBackgroundBrush}"
        Foreground="{ui:ThemeResource ApplicationForegroundBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="LblD2rExe" Grid.Row="0" Margin="0,0,0,4"/>
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TxtD2r" Grid.Column="0" Height="32"/>
            <Button x:Name="BtnBrowseD2rBtn" Grid.Column="2" Click="BtnBrowseD2r_Click" MinWidth="88"/>
        </Grid>

        <TextBlock x:Name="LblHandleExe" Grid.Row="2" Margin="0,0,0,4"/>
        <Grid Grid.Row="3" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TxtHandle" Grid.Column="0" Height="32"/>
            <Button x:Name="BtnBrowseHandleBtn" Grid.Column="2" Click="BtnBrowseHandle_Click" MinWidth="88"/>
        </Grid>

        <TextBlock x:Name="LblServer" Grid.Row="4" Margin="0,0,0,4"/>
        <TextBox x:Name="TxtServer" Grid.Row="5" Height="32" Margin="0,0,0,8"/>

        <TextBlock x:Name="LblInterval" Grid.Row="6" Margin="0,0,0,4"/>
        <TextBox x:Name="TxtInterval" Grid.Row="7" Height="32" Margin="0,0,0,8"/>

        <TextBlock x:Name="LblProfiles" Grid.Row="8" Margin="0,0,0,4"/>
        <TextBox x:Name="TxtProfilesRoot" Grid.Row="9" Height="32" Margin="0,0,0,8"/>

        <Grid Grid.Row="10" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock x:Name="LblTheme" Margin="0,0,0,4"/>
                <ComboBox x:Name="CmbTheme" Height="32">
                    <ComboBoxItem Content="dark"/>
                    <ComboBoxItem Content="light"/>
                </ComboBox>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock x:Name="LblIconStyle" Margin="0,0,0,4"/>
                <ComboBox x:Name="CmbIconStyle" Height="32">
                    <ComboBoxItem Content="gamer"/>
                    <ComboBoxItem Content="plain"/>
                </ComboBox>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="11" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock x:Name="LblLanguage" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox x:Name="CmbCulture" Width="160" Height="32">
                <ComboBoxItem Content="zh-CN"/>
                <ComboBoxItem Content="en-US"/>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="13" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnCancel" IsCancel="True" MinWidth="88" Margin="0,0,8,0"/>
            <Button x:Name="BtnOk" Click="BtnOk_Click" MinWidth="88"/>
        </StackPanel>
    </Grid>
</Window>
