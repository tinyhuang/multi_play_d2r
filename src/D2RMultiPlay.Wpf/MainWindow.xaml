<Window x:Class="D2RMultiPlay.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:D2RMultiPlay.Wpf"
        mc:Ignorable="d"
        Title="D2R Multi-Play Manager" Height="820" Width="1280"
        MinHeight="640" MinWidth="960"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Resources/app.ico"
        Background="{ui:ThemeResource ApplicationBackgroundBrush}"
        Foreground="{ui:ThemeResource ApplicationForegroundBrush}">

    <DockPanel LastChildFill="True">
        <!-- 菜单栏 -->
        <Menu DockPanel.Dock="Top" Background="{ui:ThemeResource ControlBackgroundBrush}">
            <!-- File Menu -->
            <MenuItem x:Name="MenuFileRoot" Header="File">
                <MenuItem x:Name="MenuExportEncrypted" Header="Export Encrypted..." InputGestureText="Ctrl+E" Click="MenuExportEncrypted_Click" />
                <MenuItem x:Name="MenuImportEncrypted" Header="Import Encrypted..." InputGestureText="Ctrl+I" Click="MenuImportEncrypted_Click" />
                <Separator />
                <MenuItem x:Name="MenuExportPlain" Header="Export..." Click="MenuExport_Click" />
                <MenuItem x:Name="MenuImportPlain" Header="Import..." Click="MenuImport_Click" />
                <Separator />
                <MenuItem x:Name="MenuExit" Header="Exit" InputGestureText="Alt+F4" Click="MenuExit_Click" />
            </MenuItem>

            <!-- Accounts Menu -->
            <MenuItem x:Name="MenuAccountsRoot" Header="Accounts">
                <MenuItem x:Name="MenuAddAccount" Header="Add Account..." InputGestureText="Ctrl+N" Click="MenuAddAccount_Click" />
                <MenuItem x:Name="MenuLaunchAll" Header="Launch All" InputGestureText="F5" Click="MenuLaunchAll_Click" />
                <MenuItem x:Name="MenuStopAll" Header="Stop All" InputGestureText="Shift+F5" Click="MenuStopAll_Click" />
            </MenuItem>

            <!-- Tools Menu -->
            <MenuItem x:Name="MenuToolsRoot" Header="Tools">
                <MenuItem x:Name="MenuGlobalSettings" Header="Global Settings..." InputGestureText="Ctrl+," Click="MenuGlobalSettings_Click" />
                <MenuItem x:Name="MenuMonitorLayout" Header="Game Window Layout..." InputGestureText="Ctrl+L" Click="MenuMonitorLayout_Click" />
            </MenuItem>

            <!-- View Menu -->
            <MenuItem x:Name="MenuViewRoot" Header="View">
                <MenuItem x:Name="MenuLanguageRoot" Header="Language">
                    <MenuItem x:Name="MenuLanguageZh" Header="中文" Click="MenuLanguageChinese_Click" />
                    <MenuItem x:Name="MenuLanguageEn" Header="English" Click="MenuLanguageEnglish_Click" />
                </MenuItem>
                <MenuItem x:Name="MenuThemeRoot" Header="Theme">
                    <MenuItem x:Name="MenuThemeDark" Header="Dark" Click="MenuThemeDark_Click" />
                    <MenuItem x:Name="MenuThemeLight" Header="Light" Click="MenuThemeLight_Click" />
                </MenuItem>
                <Separator />
                <MenuItem x:Name="MenuToggleLog" Header="Toggle Log" InputGestureText="Ctrl+Shift+L" Click="MenuToggleLog_Click" />
            </MenuItem>

            <!-- Help Menu -->
            <MenuItem x:Name="MenuHelpRoot" Header="Help">
                <MenuItem x:Name="MenuQuickStart" Header="Quick Start" Click="MenuQuickStart_Click" />
                <Separator />
                <MenuItem x:Name="MenuAbout" Header="About..." Click="MenuAbout_Click" />
            </MenuItem>
        </Menu>

        <!-- 主内容区 -->
        <Grid DockPanel.Dock="Top" Margin="8" Height="Auto">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 快速操作按钮 -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="BtnLaunchAll" Content="▶ Launch All" Click="BtnLaunchAll_Click" Margin="0,0,4,0" />
                <Button x:Name="BtnStopAll" Content="■ Stop All" Click="BtnStopAll_Click" Margin="0,0,4,0" />
                <Button x:Name="BtnAddAccount" Content="⌂ Add Account" Click="BtnAddAccount_Click" Margin="0,0,4,0" />
                <Button x:Name="BtnEditSelected" Content="Edit" Click="BtnEditSelected_Click" Margin="0,0,4,0" />
                <Button x:Name="BtnDeleteSelected" Content="Delete" Click="BtnDeleteSelected_Click" Margin="0,0,4,0" />
                <Button x:Name="BtnLaunchSelected" Content="Launch Selected" Click="BtnLaunchSelected_Click" Margin="0,0,4,0" />
                <Button x:Name="BtnStopSelected" Content="Stop Selected" Click="BtnStopSelected_Click" Margin="0,0,4,0" />
                <Button x:Name="BtnSettings" Content="⚙ Settings" Click="BtnSettings_Click" Margin="0,0,4,0" />
                <Button x:Name="BtnLayout" Content="Layout" Click="BtnLayout_Click" />
            </StackPanel>

            <!-- 语言/主题快速切换 -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button x:Name="BtnLangZh" Content="中" Click="BtnLangZh_Click" Width="32" Height="32" Margin="0,0,4,0" />
                <Button x:Name="BtnLangEn" Content="En" Click="BtnLangEn_Click" Width="32" Height="32" />
            </StackPanel>
        </Grid>

        <!-- 数据表格和日志 -->
        <Grid DockPanel.Dock="Top">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="200" />
            </Grid.RowDefinitions>

            <!-- DataGrid -->
            <DataGrid x:Name="DataGridAccounts" 
                      Grid.Row="0"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserResizeRows="False"
                      SelectionMode="Single"
                      SelectionChanged="DataGridAccounts_SelectionChanged"
                      MouseDoubleClick="DataGridAccounts_MouseDoubleClick"
                      Margin="8">
                <DataGrid.Columns>
                    <DataGridTemplateColumn x:Name="ColIcon" Header="Icon" Width="58">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Width="26" Height="26" CornerRadius="4" Background="#1FFFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Image Source="{Binding IconImage}" Stretch="UniformToFill" Width="24" Height="24"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn x:Name="ColId" Header="ID" Binding="{Binding Id}" Width="50" IsReadOnly="True" />
                    <DataGridCheckBoxColumn x:Name="ColEnabled" Header="Enabled" Binding="{Binding Enabled}" Width="70" IsReadOnly="True" />
                    <DataGridTextColumn x:Name="ColName" Header="Name" Binding="{Binding Name}" Width="140" IsReadOnly="True" />
                    <DataGridTextColumn x:Name="ColEmail" Header="Email" Binding="{Binding User}" Width="180" IsReadOnly="True" />
                    <DataGridTextColumn x:Name="ColRole" Header="Role" Binding="{Binding Role}" Width="90" IsReadOnly="True" />
                    <DataGridTextColumn x:Name="ColServer" Header="Server" Binding="{Binding ServerAddress}" Width="170" IsReadOnly="True" />
                    <DataGridTextColumn x:Name="ColMod" Header="Mod" Binding="{Binding Mod}" Width="100" IsReadOnly="True" />
                    <DataGridTextColumn x:Name="ColStatus" Header="Status" Binding="{Binding StatusDisplay}" Width="110" IsReadOnly="True" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- Splitter -->
            <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" />

            <!-- Log Panel -->
            <RichTextBox x:Name="RichTextBoxLog" 
                         Grid.Row="2"
                         IsReadOnly="True"
                         Background="{ui:ThemeResource ControlBackgroundBrush}"
                         Foreground="{ui:ThemeResource ControlForegroundBrush}"
                         VerticalScrollBarVisibility="Auto"
                         Margin="8" />
        </Grid>

        <!-- 状态栏 -->
        <StatusBar DockPanel.Dock="Bottom" Background="{ui:ThemeResource ControlBackgroundBrush}">
            <TextBlock x:Name="StatusLabel" Text="Ready" Foreground="{ui:ThemeResource ControlForegroundBrush}" />
        </StatusBar>
    </DockPanel>
</Window>
